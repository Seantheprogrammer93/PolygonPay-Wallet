# Copy this file to .env and fill in your RPC URLs.
# The server proxies /rpc/eth and /rpc/matic so these keys never reach the browser.
# If a variable is left blank or absent, the app falls back to public RPC endpoints.

# Ethereum mainnet — e.g. Alchemy: https://eth-mainnet.g.alchemy.com/v2/YOUR_KEY
RPC_ETH_URL=

# Polygon mainnet — e.g. Alchemy: https://polygon-mainnet.g.alchemy.com/v2/YOUR_KEY
RPC_MATIC_URL=
